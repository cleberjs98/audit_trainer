# Required for Supabase Auth and database access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required in production so invite emails and auth callbacks use the deployed URL.
APP_BASE_URL=

# Optional for real team invitation emails.
# If these are not configured, Team Management keeps the manual invite-link fallback.
RESEND_API_KEY=
INVITE_EMAIL_FROM=

# Future/server-only features.
# Do not set SUPABASE_SERVICE_ROLE_KEY unless a future server-only feature requires it.
# OPENAI_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
